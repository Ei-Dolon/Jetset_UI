{
	"short_name": "jetsetui",
	"name": "JetsetUI",
	"description": "Jetset DApp Frontend",
	"start_url": "/",
	"display": "standalone",
	"theme_color": "#0090e7",
	"background_color": "#121212",
	"icons": [
		{
			"src": "./icons/Jetset.svg",
			"type": "image/svg+xml",
			"sizes": "any"
		},
		{
			"src": "./icons/favicon.ico",
			"sizes": "16x16 32x32 48x48",
			"type": "image/x-icon"
		},
		{
			"src": "./icons/apple-touch-icon.png",
			"sizes": "180x180",
			"type": "apple-touch-icon"
		},
		{
			"src": "./icons/icon-192.png",
			"sizes": "192x192",
			"type": "image/png"
		},		
		{
			"src": "./icons/icon-512.png",
			"sizes": "512x512",
			"type": "image/png"
		},
	]
}
